  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#7A9AB5",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#1A8A3A"
      }
    },
    {
      "name": "String escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "Number / Constant / Boolean",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.undefined",
        "constant.language.nan",
        "constant.language.infinity",
        "constant.other.color",
        "support.constant"
      ],
      "settings": {
        "foreground": "#6B3EC4"
      }
    },
    {
      "name": "Keyword / Storage / Control",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.delete",
        "keyword.operator.typeof",
        "keyword.operator.void",
        "keyword.operator.instanceof",
        "keyword.operator.in",
        "keyword.operator.of",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#CC0070"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.accessor"
      ],
      "settings": {
        "foreground": "#0070CC"
      }
    },
    {
      "name": "Type / Class / Interface",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.interface",
        "entity.name.enum",
        "entity.other.inherited-class",
        "support.type",
        "support.class",
        "meta.return-type",
        "meta.type-annotation",
        "meta.type.annotation",
        "storage.type.class",
        "keyword.type"
      ],
      "settings": {
        "foreground": "#007A65"
      }
    },
    {
      "name": "Function / Method",
      "scope": [
        "entity.name.function",
        "meta.function-call.generic",
        "support.function",
        "meta.require"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other.readwrite"
      ],
      "settings": {
        "foreground": "#0D2040"
      }
    },
    {
      "name": "Variable — parameter",
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#0D2040",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace",
        "meta.bracket",
        "meta.paren"
      ],
      "settings": {
        "foreground": "#4A6A8A"
      }
    },
    {
      "name": "HTML — tag name",
      "scope": [
        "entity.name.tag",
        "meta.tag.sgml"
      ],
      "settings": {
        "foreground": "#CC0070"
      }
    },
    {
      "name": "HTML — attribute name",
      "scope": [
        "entity.other.attribute-name",
        "meta.tag.attributes"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "HTML — attribute value",
      "scope": [
        "string.quoted.double.html",
        "string.quoted.single.html"
      ],
      "settings": {
        "foreground": "#1A8A3A"
      }
    },
    {
      "name": "CSS — selector",
      "scope": [
        "entity.name.tag.css",
        "entity.other.attribute-name.class.css",
        "entity.other.attribute-name.id.css",
        "entity.other.attribute-name.pseudo-class.css",
        "entity.other.attribute-name.pseudo-element.css"
      ],
      "settings": {
        "foreground": "#CC0070"
      }
    },
    {
      "name": "CSS — property",
      "scope": [
        "support.type.property-name.css",
        "meta.property-name.css"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "CSS — value / unit",
      "scope": [
        "meta.property-value.css",
        "support.constant.property-value.css",
        "constant.numeric.css",
        "keyword.other.unit.css"
      ],
      "settings": {
        "foreground": "#6B3EC4"
      }
    },
    {
      "name": "Markdown — heading",
      "scope": [
        "markup.heading",
        "punctuation.definition.heading.markdown"
      ],
      "settings": {
        "foreground": "#0070CC",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — bold",
      "scope": [
        "markup.bold",
        "punctuation.definition.bold.markdown"
      ],
      "settings": {
        "foreground": "#C04A00",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown — italic",
      "scope": [
        "markup.italic",
        "punctuation.definition.italic.markdown"
      ],
      "settings": {
        "foreground": "#CC0070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — inline code",
      "scope": [
        "markup.inline.raw.string.markdown"
      ],
      "settings": {
        "foreground": "#007A65"
      }
    },
    {
      "name": "Markdown — link",
      "scope": [
        "markup.underline.link.markdown",
        "markup.underline.link.image.markdown",
        "meta.link.inline.markdown",
        "meta.link.reference.markdown"
      ],
      "settings": {
        "foreground": "#007A65",
        "fontStyle": "underline"
      }
    },
    {
      "name": "Markdown — quote",
      "scope": [
        "markup.quote.markdown",
        "punctuation.definition.quote.begin.markdown"
      ],
      "settings": {
        "foreground": "#4A6A8A",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown — list bullet",
      "scope": [
        "beginning.punctuation.definition.list.markdown",
        "punctuation.definition.list.begin.markdown"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "Invalid / Deprecated",
      "scope": [
        "invalid",
        "invalid.deprecated"
      ],
      "settings": {
        "foreground": "#CC0070"
      }
    },
    {
      "name": "Diff — inserted",
      "scope": [
        "markup.inserted",
        "meta.diff.header.to-file"
      ],
      "settings": {
        "foreground": "#1A8A3A"
      }
    },
    {
      "name": "Diff — deleted",
      "scope": [
        "markup.deleted",
        "meta.diff.header.from-file"
      ],
      "settings": {
        "foreground": "#CC0070"
      }
    },
    {
      "name": "Diff — changed",
      "scope": [
        "markup.changed"
      ],
      "settings": {
        "foreground": "#B07000"
      }
    },
    {
      "name": "JSON — key",
      "scope": [
        "support.type.property-name.json"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "YAML — key",
      "scope": [
        "entity.name.tag.yaml"
      ],
      "settings": {
        "foreground": "#C04A00"
      }
    },
    {
      "name": "YAML — anchor / alias",
      "scope": [
        "entity.name.type.anchor.yaml",
        "variable.other.alias.yaml"
      ],
      "settings": {
        "foreground": "#6B3EC4"
      }
    },
    {
      "name": "Python — self / cls",
      "scope": [
        "variable.language.special.self.python",
        "variable.language.special.cls.python"
      ],
      "settings": {
        "foreground": "#CC0070",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Python — decorator",
      "scope": [
        "entity.name.function.decorator.python",
        "punctuation.definition.decorator.python"
      ],
      "settings": {
        "foreground": "#B07000"
      }
    },
    {
      "name": "Rust — lifetime",
      "scope": [
        "entity.name.lifetime.rust",
        "storage.modifier.lifetime.rust",
        "punctuation.definition.lifetime.rust"
      ],
      "settings": {
        "foreground": "#6B3EC4",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Import / Module path",
      "scope": [
        "entity.name.module",
        "support.module",
        "keyword.control.import",
        "keyword.control.export",
        "keyword.control.from",
        "keyword.control.as"
      ],
      "settings": {
        "foreground": "#CC0070"
      }
    },
    {
      "name": "Flow",
      "scope": [
        "keyword.control.export",
        "keyword.control.flow",
        "keyword.control.trycatch"
      ],
      "settings": {
        "fontStyle": "underline"
      }
    }
  ],

  "semanticTokenColors": {
